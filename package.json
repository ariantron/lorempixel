{
  "name": "lorempixar",
  "version": "1.0.0",
  "description": "Generate placeholder images with custom width, height, background color, text color, and text",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun run test.ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "placeholder",
    "image",
    "placeholder-image",
    "svg",
    "dummy",
    "lorem",
    "pixel"
  ],
  "license": "MIT",
  "optionalDependencies": {
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.1.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
