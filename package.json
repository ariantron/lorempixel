{
  "name": "lorempixel",
  "version": "1.0.1",
  "description": "Generate placeholder images with custom width, height, background color, text color, and text",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/ariantron/lorempixel.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun run test.ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "placeholder",
    "image",
    "placeholder-image",
    "svg",
    "dummy",
    "lorem",
    "pixel"
  ],
  "license": "MIT",
  "optionalDependencies": {
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.1.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
